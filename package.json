{
  "name": "@codealive/installer",
  "version": "1.0.8",
  "packageManager": "pnpm@10.33.0",
  "description": "Install CodeAlive MCP server, skill, and plugin to your AI coding agents",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "codealive-installer": "dist/bin.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/bin.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build && pnpm test && pnpm typecheck"
  },
  "keywords": [
    "codealive",
    "mcp",
    "model-context-protocol",
    "ai",
    "coding-agent",
    "installer",
    "cursor",
    "claude",
    "claude-code",
    "vscode",
    "copilot",
    "windsurf",
    "cline",
    "zed",
    "skill"
  ],
  "author": "CodeAlive AI",
  "license": "MIT",
  "homepage": "https://docs.codealive.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CodeAlive-AI/codealive-installer.git"
  },
  "bugs": {
    "url": "https://github.com/CodeAlive-AI/codealive-installer/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@clack/prompts": "0.9.1",
    "chalk": "5.6.2",
    "jsonc-parser": "3.3.1",
    "open": "10.2.0",
    "yargs": "17.7.2"
  },
  "devDependencies": {
    "@types/node": "20.19.33",
    "@types/yargs": "17.0.35",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "2.1.9"
  }
}
